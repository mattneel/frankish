# frankish — version pins. THE single pin point (SPEC §12; M0 exit criterion).
#
# Plain KEY=VALUE lines only: this file is `include`d by GNU make and
# `.`-sourced by POSIX sh. No quotes, no export, no inline comments.
# Every mirror of these values elsewhere (rust-toolchain.toml, Cargo.toml,
# the Makefile's mlir-sys env var names) is asserted by scripts/check-pins.sh;
# extend that script in the same commit that adds a new mirror (law L1).

# Rust toolchain (mirrored in rust-toolchain.toml)
RUST_TOOLCHAIN=1.96.0

# LLVM/MLIR major (apt.llvm.org / brew llvm@22). The mlir-sys/tblgen build
# env var names derive from this: MLIR_SYS_220_PREFIX, TABLEGEN_220_PREFIX.
LLVM_MAJOR=22

# Exact LLVM/MLIR version the suite was last proven against (informational).
LLVM_VERSION_TESTED=22.1.8

# melior (Rust MLIR bindings; mlir-rs). Exact-pinned in Cargo.toml (=x.y.z);
# tracks LLVM/MLIR 22 per docs/LANDSCAPE.md. Bump deliberately, never
# implicitly (LANDSCAPE watch item).
MELIOR_VERSION=0.27.2

# ml_core oracle (M5): the ocaml toplevel the corpus was last proven
# against (informational; setup.sh checks presence).
OCAML_VERSION_TESTED=4.14.1

# The cross C driver (M7 grid; D-018/D-042). scripts/zigcc.sh resolves
# a plain zig or an anyzig-style shim against this pin.
ZIG_VERSION=0.16.0

# Grid executors (M7; informational — setup.sh checks presence):
# qemu-user for aarch64/riscv64/s390x, wasmtime for wasm32-wasi.
WASMTIME_VERSION_TESTED=46.0.1

# femto_lua oracle (M10 ratification; implementation later): the
# PUC-Rio interpreter, exact-pinned — 5.1.5 is the spec.
LUA_VERSION_TESTED=5.1.5

# node runs tools/loanword-ts directly (native type stripping) and is
# the TS-0 oracle; the typescript package pin lives in
# tools/loanword-ts/package.json (TS 6.0.3, checker-as-oracle).
NODE_MIN_MAJOR=20
